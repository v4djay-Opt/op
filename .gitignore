# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep .env.example committed, ignore everything else
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# build/dev logs
*-log.txt
init-log.txt

# additional build output
dist/

# editor files
.vscode/
.idea/
*.suo
.ntvs_analysis.dat
*.njsproj
*.sln

# os files
Thumbs.db

# temp / backup files
*.bak
*.backup
*.tmp

# sanity local cache
.sanity/

# turbo cache
.turbo/

# coverage reports
coverage/

# planning / scratch files
seo-content-brief.md
seo-keywords-strategy.md
